# SudokuAI Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# Google Gemini API Key
# Get it free from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# API Endpoint (optional, change if using different model)
VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent

# Deployment
VITE_ENVIRONMENT=development
